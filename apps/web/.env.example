# Convex deployment URLs (set in apps/web/.env.local for local dev).
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=

# Phase 6 (PWA) — Web Push public VAPID key, exposed to the browser.
# Must match VAPID_PUBLIC_KEY on the Convex deployment.
# Generate with: bunx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
