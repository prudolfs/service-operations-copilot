# Convex deployment (auto-populated by `convex dev`).
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SITE_URL=

# Better Auth — set these on the Convex deployment via dashboard or
# `bunx convex env set`. Do NOT commit real values.
BETTER_AUTH_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public site URL Better Auth will bounce through (web app once it deploys).
SITE_URL=

# Role assignment lists (comma-separated, lowercase emails).
# Email matched against ADMIN_EMAILS → manager, WORKER_EMAILS → worker, else client.
ADMIN_EMAILS=
WORKER_EMAILS=

# Phase 6 — AI features. Set on the Convex deployment via dashboard or
# `bunx convex env set`. The .env.local file does not sync to runtime.
#
# Groq — used by `ai/transcribe.ts` for audio transcription (Whisper).
# Get a key at https://console.groq.com/keys (free tier covers dev).
GROQ_API_KEY=
#
# Vercel AI Gateway — used by `ai/askAnything.ts`, `ai/replySuggestions.ts`,
# and `ai/summary.ts` via `createGateway()`. Lets us swap models without
# rebuilding clients. Get a key at https://vercel.com/dashboard/ai-gateway.
AI_GATEWAY_API_KEY=
#
# OR direct provider keys (only needed if you skip the gateway above).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Phase 6 (PWA) — Web Push (VAPID). Generate once with:
#   bunx web-push generate-vapid-keys
# Set on the Convex deployment via dashboard or `bunx convex env set`.
# The .env.local file does not sync to Convex runtime.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Required by RFC 8292; identifies the push sender to the push service.
VAPID_SUBJECT=mailto:ops@service-ops.local
