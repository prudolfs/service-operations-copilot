# Convex deployment (auto-populated by `convex dev`).
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SITE_URL=

# Better Auth — set these on the Convex deployment via dashboard or
# `bunx convex env set`. Do NOT commit real values.
BETTER_AUTH_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public site URL Better Auth will bounce through (web app once it deploys).
SITE_URL=

# Role assignment lists (comma-separated, lowercase emails).
# Email matched against ADMIN_EMAILS → manager, WORKER_EMAILS → worker, else client.
ADMIN_EMAILS=
WORKER_EMAILS=
